APP_URL="MY_APP_URL"

# Optional override. Defaults to the deployed event backend.
VITE_EVENT_API_BASE="https://show-plan-event-backend.liucheng-show-plan.workers.dev"

# Optional override for the upload proxy base.
# Leave empty to call same-origin /api/uploads/* routes.
VITE_UPLOAD_API_BASE=""

# Cloudflare Images upload proxy credentials.
CLOUDFLARE_ACCOUNT_ID="MY_CLOUDFLARE_ACCOUNT_ID"
CLOUDFLARE_IMAGES_API_TOKEN="MY_CLOUDFLARE_IMAGES_API_TOKEN"
CLOUDFLARE_IMAGES_ACCOUNT_HASH="MY_CLOUDFLARE_IMAGES_ACCOUNT_HASH"
CLOUDFLARE_IMAGES_VARIANT="public"
